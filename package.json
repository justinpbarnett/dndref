{
  "name": "dnd-ref",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo start --ios",
    "scrape:discover": "node scripts/scrape-vvd.mjs",
    "scrape:export": "node scripts/scrape-vvd.mjs --export",
    "proxy:dev": "wrangler dev --config workers/cors-proxy/wrangler.toml",
    "proxy:deploy": "wrangler deploy --config workers/cors-proxy/wrangler.toml",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-av": "~15.0.2",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "fuse.js": "^7.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-web": "~0.19.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "~18.3.0",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.32.0",
    "playwright": "^1.58.2",
    "typescript": "~5.3.3",
    "vitest": "^4.1.2"
  }
