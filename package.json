{
  "name": "dnd-ref",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "ios": "expo start --ios",
    "scrape:discover": "node scripts/scrape-vvd.mjs",
    "scrape:export": "node scripts/scrape-vvd.mjs --export",
    "proxy:dev": "wrangler dev --config workers/cors-proxy/wrangler.toml",
    "proxy:deploy": "wrangler deploy --config workers/cors-proxy/wrangler.toml",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.10",
    "@expo/vector-icons": "^15.1.1",
