    "expo": "~55.0.17",
    "expo-audio": "~55.0.14",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "fuse.js": "^7.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@playwright/test": "^1.58.2",
    "@types/react": "~19.2.10",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.32.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.2",
